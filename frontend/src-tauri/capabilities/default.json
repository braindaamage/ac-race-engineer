{
  "identifier": "default",
  "description": "Default capabilities for the AC Race Engineer app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/api-server",
          "sidecar": true,
          "args": ["--port", { "validator": "\\d+" }]
        }
      ]
    },
    "shell:allow-kill"
  ]
}
